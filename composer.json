{
  "name": "noscrape/wordpress",
  "description": "WordPress plugin for Noscrape server-side obfuscation.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Bernhard Schönberger",
      "homepage": "https://noscrape.eu"
    }
  ],
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "php-stubs/wordpress-stubs": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "Noscrape\\WordPress\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Noscrape\\WordPress\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist"
  }
}
